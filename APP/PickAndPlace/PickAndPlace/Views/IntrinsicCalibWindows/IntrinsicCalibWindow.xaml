<Window
    x:Class="PickAndPlace.Views.IntrinsicCalibWindows.IntrinsicCalibWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PickAndPlace.Views.IntrinsicCalibWindows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:myControl="clr-namespace:Heal.MyControl;assembly=ImageCtlWPF"
    Title="Hand-Eye 2D Calibration"
    Width="1300"
    Height="768"
    Icon="/Resources/Icons/robot-arm.png"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="450" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1">
            <Border
                Width="1"
                Margin="0,5,0,5"
                Background="DarkGray" />
        </Grid>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="150" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <GroupBox
                    Margin="10,5,5,5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Header="Camera Intrinsic Calib" />
            </Grid>
            <Grid Grid.Row="1">
                <GroupBox
                    Margin="10,5,5,5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Header="Camera View">
                    <myControl:ImageBox
                        x:Name="imbImage"
                        Margin="5"
                        Background="LightGray" />

                </GroupBox>
            </Grid>
        </Grid>

    </Grid>
</Window>
