<Window
    x:Class="PickAndPlace.Views.ModelsManagerWindows.TemplatesSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PickAndPlace.Views.ModelsManagerWindows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:myControl="clr-namespace:Heal.MyControl;assembly=ImageCtlWPF"
    xmlns:uc="clr-namespace:PickAndPlace.Resources.Styles"
    xmlns:utils="clr-namespace:PickAndPlace.Utils"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    Title="Templates Selection"
    Width="1224"
    Height="800"
    Closing="Window_Closing"
    Icon="/Resources/Icons/robot-arm.png"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    Style="{StaticResource WindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <GroupBox BorderBrush="Gray" Header="Captured Image">
                <myControl:ImageBox
                    x:Name="imbFOV"
                    Margin="5"
                    Background="LightGray"
                    MouseClick="imbFOV_MouseClick"
                    MouseMove="imbFOV_MouseMove"
                    PreviewMouseDown="imbFOV_PreviewMouseDown"
                    PreviewMouseUp="imbFOV_PreviewMouseUp"
                    ShowCorner="False" />
            </GroupBox>
        </Grid>
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="127" />
                <RowDefinition Height="285" />
                <RowDefinition />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <GroupBox
                    Margin="5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Header="Controlling Camera">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <StackPanel VerticalAlignment="Center">
                            <ComboBox
                                x:Name="cbbCamSn"
                                Width="100"
                                Height="30"
                                Margin="5,0,0,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontSize="15" />
                            <uc:CustomButton2
                                x:Name="btnConnectCamera"
                                Title="Connect&#x0A;Camera"
                                Width="100"
                                Height="50"
                                Margin="10,5,5,5"
                                EndColor="#b6c0c5"
                                FontSize="12"
                                IconHeight="27"
                                IconWidth="30"
                                IsEnabled="{Binding CanFinish}"
                                LeftIcon="/Resources/Icons/camera-connect.png"
                                MouseDown="btnConnectCamera_MouseDown"
                                StartColor="#18a5a7" />
                        </StackPanel>
                        <Border
                            Width="1"
                            Margin="20,5,0,5"
                            Background="DarkGray" />
                        <uc:CustomButton
                            x:Name="btnCaptureImage"
                            Title="Capture"
                            Width="180"
                            Height="80"
                            Margin="15,5,5,5"
                            EndColor="#57370D"
                            IconHeight="60"
                            IconWidth="60"
                            IsEnabled="{Binding CameraConnected}"
                            LeftIcon="/Resources/Icons/capture-image.png"
                            MouseDown="btnCaptureImage_MouseDown"
                            StartColor="#ffe998"
                            Value="IMAGE" />

                    </StackPanel>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1">
                <GroupBox
                    Margin="5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Header="Image Tools">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <StackPanel
                                Margin="0,0,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Width="120"
                                    Margin="0,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Text="Image Angle: " />
                                <xctk:DoubleUpDown
                                    Name="udtbMinNGArea"
                                    Width="60"
                                    Height="40"
                                    FontSize="18"
                                    FormatString="F1"
                                    Increment="0.1"
                                    Maximum="360"
                                    Minimum="-360"
                                    PreviewTextInput="udtbPercentile_PreviewTextInput"
                                    ValueChanged="udtbMinNGArea_ValueChanged"
                                    Value="0" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1">
                            <StackPanel
                                Margin="0,0,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <uc:CustomButton2
                                    x:Name="btnAddRoi"
                                    Title="Create&#x0A;RoI"
                                    Width="100"
                                    Height="50"
                                    Margin="0,0,0,0"
                                    EndColor="#1e5b53"
                                    FontSize="12"
                                    IconHeight="40"
                                    IconWidth="35"
                                    IsEnabled="{Binding CanCalib}"
                                    LeftIcon="/Resources/Icons/robot-arm.png"
                                    MouseDown="btnAddRoi_MouseDown"
                                    StartColor="#ccffaa" />
                                <uc:CustomButton2
                                    x:Name="btnRemoveRoi"
                                    Title="Remove&#x0A;RoI"
                                    Width="100"
                                    Height="50"
                                    Margin="15,5,5,5"
                                    EndColor="#F07470 "
                                    FontSize="12"
                                    IconHeight="35"
                                    IconWidth="30"
                                    IsEnabled="{Binding CanRemove}"
                                    LeftIcon="/Resources/Icons/clear.png"
                                    MouseDown="btnRemoveRoi_MouseDown"
                                    StartColor="#F6BDC0" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="2">
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal"  Margin="0,-10,0,0">
                                <StackPanel Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Label
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="X"
                                        FontSize="12" />
                                    <TextBox
                                        Name="tbValidImageX"
                                        Width="65"
                                        Height="25"
                                        Margin="5,-5,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="DarkGray"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        IsReadOnly="True" />
                                </StackPanel>
                                <StackPanel Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Label
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="Y"
                                        FontSize="12" />
                                    <TextBox
                                        Name="tbValidImageY"
                                        Width="65"
                                        Height="25"
                                        Margin="5,-5,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="DarkGray"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        IsReadOnly="True" />
                                </StackPanel>
                                <StackPanel Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Label
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="Width"
                                        FontSize="12" />
                                    <TextBox
                                        Name="tbValidImageW"
                                        Width="65"
                                        Height="25"
                                        Margin="5,-5,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="DarkGray"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        IsReadOnly="True" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,0" VerticalAlignment="Center">
                                    <Label
                                        Margin="0,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="Height"
                                        FontSize="12" />
                                    <TextBox
                                        Name="tbValidHeightW"
                                        Width="65"
                                        Height="25"
                                        Margin="5,-5,0,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        BorderBrush="DarkGray"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        IsReadOnly="True" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="3">
                            <uc:CustomButton2
                                x:Name="btnAddTemplate"
                                Title="Add&#x0A;Template"
                                Width="115"
                                Height="50"
                                Margin="0,-10,0,0"
                                EndColor="#1e5b53"
                                FontSize="12"
                                IconHeight="40"
                                IconWidth="35"
                                IsEnabled="{Binding CanCalib}"
                                LeftIcon="/Resources/Icons/robot-arm.png"
                                MouseDown="btnAddTemplate_MouseDown"
                                StartColor="#ccffaa" />
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="2">
                <GroupBox
                    Margin="5"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Header="Templates Manager">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <myControl:ImageBox
                                x:Name="imbTemplate"
                                Margin="15,5,15,5"
                                Background="LightGray" />
                        </Grid>
                        <Grid Grid.Row="1">
                            
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="3">
                <StackPanel
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <uc:CustomButton2
                        x:Name="btnCancel"
                        Title="Cancel&#x0A;Process"
                        Width="105"
                        Height="50"
                        Margin="0,0,10,0"
                        EndColor="#1e5b53"
                        FontSize="12"
                        IconHeight="40"
                        IconWidth="35"
                        IsEnabled="{Binding CanCalib}"
                        LeftIcon="/Resources/Icons/robot-arm.png"
                        MouseDown="btnCancel_MouseDown"
                        StartColor="#ccffaa" />
                    <uc:CustomButton2
                        x:Name="btnSave"
                        Title="Save&#x0A;Settings"
                        Width="105"
                        Height="50"
                        Margin="0,0,0,0"
                        EndColor="#1e5b53"
                        FontSize="12"
                        IconHeight="40"
                        IconWidth="35"
                        IsEnabled="{Binding CanCalib}"
                        LeftIcon="/Resources/Icons/robot-arm.png"
                        MouseDown="btnSave_MouseDown"
                        StartColor="#ccffaa" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
